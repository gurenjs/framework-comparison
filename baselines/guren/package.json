{
  "name": "guren",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "bunx guren codegen --force",
    "dev": "bun run codegen && bun run dev:server",
    "dev:server": "bun bin/serve.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run codegen && bunx vite build && bunx vite build --ssr",
    "preview": "NODE_ENV=production bun bin/serve.ts",
    "db:make": "bunx guren make:migration",
    "db:migrate": "bunx guren db:migrate",
    "db:reset": "bunx guren db:reset",
    "db:status": "bunx guren db:status",
    "db:seed": "bunx guren db:seed"
  },
  "dependencies": {
    "@guren/cli": "^1.0.0-rc.11",
    "@guren/core": "^1.0.0-rc.11",
    "@guren/inertia-client": "^1.0.0-rc.11",
    "@guren/orm": "^1.0.0-rc.11",
    "@inertiajs/react": "^2.3.18",
    "drizzle-orm": "1.0.0-rc.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-types": "^1.3.1",
    "drizzle-kit": "1.0.0-rc.1",
    "mysql2": "^3.11.3",
    "postgres": "^3.4.3",
    "typescript": "^5.4.0",
    "@vitejs/plugin-react": "^6.0.0",
    "vite": "^8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2"
  }
}
